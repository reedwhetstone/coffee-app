# E2E Test Configuration
# Copy this to .env.test and fill in your test account credentials

# Test account for E2E testing (admin magic-link auth)
E2E_TEST_EMAIL=your-test-email@example.com
E2E_TEST_USER_ID=your-test-user-uuid

# Supabase service role key (required to generate magic links for E2E auth)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public Supabase config required by SvelteKit static env imports during validation
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe placeholders required by static validation; use non-production test values locally
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Base URL for tests (defaults to localhost:5173)
PLAYWRIGHT_BASE_URL=http://localhost:5173
